{
  "title": "Soyo Appliance",
  "tags": [
    "soyo",
    "nixos"
  ],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Uptime",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "node_time_seconds - node_boot_time_seconds",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "DNS Queries",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dnsmasq_hits[$__rate_interval]))",
          "legendFormat": "queries/s",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DHCP Leases",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "dnsmasq_leases",
          "legendFormat": "leases",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "DNS & DHCP",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 5
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "DNS Query Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dnsmasq_hits[$__rate_interval]))",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Blocked Queries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(dnsmasq_misses[$__rate_interval]))",
          "legendFormat": "blocked",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Active DHCP Leases",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 30,
                "color": "orange"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "dnsmasq_leases",
          "legendFormat": "leases",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "title": "System Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 9
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Recent Journal",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "loki",
        "uid": "soyo-loki"
      },
      "targets": [
        {
          "expr": "{host=\"soyo\"} |= \"\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogJson": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    },
    {
      "title": "Traces",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 11
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Boot Traces Available",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "tempo",
        "uid": "soyo-tempo"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "{service.name=\"systemd-boot\"} | count()",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "description": "Boot traces are generated automatically after each reboot via systemd-analyze. Explore them in Grafana's Explore view → select Tempo datasource → use TraceQL query: {service.name=\"systemd-boot\"}",
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Backup Traces",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 35
      },
      "datasource": {
        "type": "tempo",
        "uid": "soyo-tempo"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "{service.name=\"restic-backup\"} | count()",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "description": "Generated after each restic backup run (daily). Shows backup duration and success/failure.",
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Activation Traces",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 35
      },
      "datasource": {
        "type": "tempo",
        "uid": "soyo-tempo"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "{service.name=\"nixos-activation\"} | count()",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "description": "Generated on each nixos-rebuild activation. Shows generation changes over time.",
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "Health Check Traces",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 35
      },
      "datasource": {
        "type": "tempo",
        "uid": "soyo-tempo"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "none"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              }
            ]
          }
        }
      },
      "targets": [
        {
          "query": "{service.name=\"soyo-health\"} | count()",
          "queryType": "traceql",
          "refId": "A"
        }
      ],
      "description": "Hourly checks: disk usage, systemd health, memory, zram. Red spans = check failed.",
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      }
    }
  ]
}